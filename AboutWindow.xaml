<Window x:Class="AudioAnalyzer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:AudioAnalyzer.Infrastructure"
        Title="Acerca De - Tone And Beat's by Hostility"
        Height="910" Width="460"
        MinHeight="350" MinWidth="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        infra:CornerResizeBehavior.EnableOnlyCornerResize="True">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <infra:PlayScaleTextConverter x:Key="PlayScaleTextConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}"/>
        </Style>
        
        <Style x:Key="BrutalistSectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{DynamicResource ResultBoxBackgroundBrush}"/>
        </Style>

        <Style x:Key="KoFiButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="White" BorderThickness="2" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="[ INVÍTAME A UNA COSITA? CLICK AQUÍ ]" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border x:Name="MainBorder" 
            Background="{DynamicResource BackgroundBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1" 
            Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Height="30" Background="{DynamicResource ResultBoxBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="ABOUT / TONE &amp; BEATS" 
                           VerticalAlignment="Center" 
                           Margin="15,0,0,0" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource AccentBrush}"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="[ X ]" 
                            Click="CloseButton_Click" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Foreground="White" 
                            Width="40" 
                            Cursor="Hand"
                            FontFamily="{DynamicResource TerminalFont}"/>
                </StackPanel>
            </Grid>

            <!-- Main container -->
            <Grid Grid.Row="1" x:Name="ContentGrid" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/> <!-- New Update Section -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Section 0: Title & Version -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="TONE &amp; BEATS" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource TitleBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="BY HOSTILITY" FontSize="14" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                    <TextBlock x:Name="VersionText" Text="VERSION" FontSize="10" 
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Section 1: Brand Logo -->
                 <Image x:Name="LogoImageAbout" Grid.Row="1" Height="40" 
                        HorizontalAlignment="Center" Margin="0,5,0,15"/>

                <!-- Section 2: Update Status -->
                <Border Grid.Row="2" Style="{StaticResource BrutalistSectionBorder}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text=">_ ACTUALIZACIONES:" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="UpdateStatusText" Text="ESTADO: BUSCANDO..." FontSize="10" Foreground="White"/>
                                <TextBlock x:Name="UpdateDetailsText" Text="SIN NOVEDADES" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="UpdateActionButton" Grid.Column="1" 
                                    Content="[ BUSCAR ]" 
                                    Click="UpdateActionButton_Click"
                                    Background="Transparent" BorderThickness="0" 
                                    Foreground="{DynamicResource AccentBrush}" 
                                    FontSize="10" Cursor="Hand" Padding="10,5"/>
                        </Grid>
                        
                        <!-- Progress Area (Hidden by default) -->
                        <StackPanel x:Name="UpdateProgressArea" Visibility="Collapsed" Margin="0,10,0,0">
                            <ProgressBar x:Name="UpdateProgressBar" Height="2" Background="#333" Foreground="{DynamicResource AccentBrush}" BorderThickness="0" Value="0" Maximum="100"/>
                            <TextBlock x:Name="UpdateProgressText" Text="DESCARGANDO: 0%" FontSize="8" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Section 3: Libraries & Modules -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5" Background="{DynamicResource ResultBoxBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text=">_ LIBRARIES &amp; MODULES:" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,5,0,10"/>
                            
                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="NAUDIO 2.2.1" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="MARK HEATH | MIT" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Audio playback, waveform generation, tone synthesis" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/naudio/NAudio" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="NAUDIO.VORBIS 1.5.0" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="NAUDIO | MIT" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="OGG Vorbis audio format support" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/naudio/Vorbis" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>
                            
                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="TAGLIBSHARP 2.3.0" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="MONO PROJECT | LGPL-2.1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Audio metadata reading and writing (BPM, Key tags)" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/mono/taglib-sharp" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>
                            
                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="SOUNDTOUCH.NET 2.3.2" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="OLAF WOUDENBERG | LGPL-2.1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Audio time-stretching and pitch-shifting" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/owoudenberg/soundtouch.net" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>
                            
                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="FFMPEGCORE 5.1.0" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="VLAD JERCA | MIT" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text=".NET wrapper for FFmpeg CLI operations" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/rosenbjerg/FFMpegCore" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="MEDIAINFO.WRAPPER.CORE 26.1.0" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="MEDIAAREA | BSD-2-CLAUSE" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Detailed audio file metadata extraction (bitrate, codec)" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/MediaArea/MediaInfoLib" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="SKIASHARP 2.88.8" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="MONO / MICROSOFT | MIT" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="2D graphics engine for waveform rendering" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/mono/SkiaSharp" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="ARDALIS.SPECIFICATION 9.3.1" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="STEVE SMITH | MIT" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Specification pattern for query abstractions" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/ardalis/Specification" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <TextBlock Text=">_ EXTERNAL TOOLS:" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,8"/>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="FFMPEG" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="FFMPEG TEAM | GPL-3.0 / LGPL-2.1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="Audio decoding, loudness analysis (LUFS/LRA)" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://ffmpeg.org" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ FFMPEG.ORG ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>

                            <Border Style="{StaticResource BrutalistSectionBorder}">
                                <StackPanel>
                                     <TextBlock Text="ESSENTIA" FontWeight="Bold" FontSize="12"/>
                                     <TextBlock Text="MTG / UPF | AGPL-3.0" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                     <TextBlock Text="BPM detection engine (streaming extractor)" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                     <TextBlock FontSize="9">
                                         <Hyperlink NavigateUri="https://github.com/MTG/essentia" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">[ GITHUB ]</Hyperlink>
                                     </TextBlock>
                                 </StackPanel>
                             </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Section 4: Support Message -->
                <TextBlock Grid.Row="4" FontSize="10" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,15,0,10">
                    ESTE PROYECTO NACIÓ DE LAS GANAS DE COMPARTIR ALGO ÚTIL. SI TE GUSTA Y QUIERES APOYAR, TU DONACIÓN ME MOTIVA A SEGUIR INNOVANDO.
                </TextBlock>
                
                <!-- Section 5: Donation Button -->
                <Button Grid.Row="5" Style="{StaticResource KoFiButton}" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,15"
                        Click="KoFiButton_Click"/>
                
                <!-- Section 6: QR Code -->
                <Border Grid.Row="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,15" Background="White" Padding="5">
                    <Image x:Name="QrImage" Height="120" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Cursor="Hand"
                           MouseLeftButtonDown="QrImage_Click"
                           ToolTip="CLIC PARA AMPLIAR"/>
                </Border>
                
                <!-- Section 7: Contact & Website -->
                <StackPanel Grid.Row="7" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock FontSize="12" HorizontalAlignment="Center">
                        <Hyperlink NavigateUri="https://www.hostilitymusic.com" 
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource AccentBrush}">WWW.HOSTILITYMUSIC.COM</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="INFO@HOSTILITYMUSIC.COM" FontSize="10" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Section 8: Footer -->
                <TextBlock Grid.Row="8" FontSize="9" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,0"
                           TextAlignment="Center">
                    © 2026 HOSTILITY MUSIC. TODOS LOS DERECHOS RESERVADOS.
                </TextBlock>
            </Grid>
            
            <!-- Lightbox Overlay -->
            <Grid x:Name="QrOverlay" Visibility="Collapsed" Background="#F2000000" MouseLeftButtonDown="QrOverlay_Click" Panel.ZIndex="100">
                <Border BorderBrush="White" BorderThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                    <Image x:Name="QrOverlayImage" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Cursor="Hand"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
