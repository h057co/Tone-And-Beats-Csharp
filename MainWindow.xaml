<Window x:Class="AudioAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AudioAnalyzer.Controls"
        xmlns:themes="clr-namespace:AudioAnalyzer.Themes"
        xmlns:infra="clr-namespace:AudioAnalyzer.Infrastructure"
        mc:Ignorable="d"
        Title="Tone &amp; Beats by Hostility" 
        Width="490" Height="720"
        MinWidth="490" MinHeight="650"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowDrop="True"
        StateChanged="Window_StateChanged"
        SizeChanged="Window_SizeChanged"
        FontFamily="{DynamicResource AppFontFamily}"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        DataContext="{Binding}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome 
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            CaptionHeight="24"
            CornerRadius="10,10,10,10"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <infra:ScaleNoteHighlightConverter x:Key="ScaleNoteHighlightConverter"/>
        <infra:LevelToBrushConverter x:Key="LevelToBrushConverter"/>
        <infra:PlayScaleTextConverter x:Key="PlayScaleTextConverter"/>
        <infra:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <infra:TonicMarkerVisibilityConverter x:Key="TonicMarkerVisibilityConverter"/>
        <infra:DoubleToVisibilityConverter x:Key="DoubleToVisibilityConverter"/>
        <infra:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <infra:ProgressWidthConverter x:Key="ProgressWidthConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="{DynamicResource ControlCornerRadius}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ButtonDisabledBrush}"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="AnalyzeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AnalyzeButtonBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AnalyzeButtonHoverBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsAnalyzingInProgress}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PulseStoryboard">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.6" Duration="0:0:0.5"
                                                 AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SaveMetadataButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource ResultBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ResultBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResultBox" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ResultBoxBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
            <Setter Property="BorderThickness" Value="{DynamicResource ControlBorderThickness}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="{DynamicResource ControlPadding}"/>
            <Setter Property="Margin" Value="{DynamicResource SectionMargin}"/>
        </Style>
        
        <!-- ComboBox ToggleButton Template -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" 
                        Background="{DynamicResource ComboBoxBackgroundBrush}" 
                        BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                        BorderThickness="1" CornerRadius="{DynamicResource ControlCornerRadius}"/>
                <Border Grid.Column="0" Background="Transparent" Margin="1"/>
                <Path x:Name="Arrow" Grid.Column="1" 
                      Fill="{DynamicResource ComboBoxForegroundBrush}" 
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        
        <!-- ComboBox Style with High Contrast -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                         Template="{StaticResource ComboBoxToggleButton}"
                                         IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                         Focusable="False"
                                         ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" 
                                            IsHitTestVisible="False"
                                            Content="{TemplateBinding SelectionBoxItem}" 
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Margin="8,3,24,3"/>
                            <Popup Name="Popup" 
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown" 
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="{DynamicResource ComboBoxBackgroundBrush}" 
                                            BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                                            BorderThickness="1" CornerRadius="{DynamicResource ControlCornerRadius}"
                                            Margin="0,1,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="1,2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <!-- Window Container: Border with rounded corners and shadow -->
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{DynamicResource WindowCornerRadius}"
            Margin="10"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="{DynamicResource MainBorderThickness}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Row 0: Custom Title Bar (24px) -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="{DynamicResource HeaderCornerRadius}">
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="TONE&amp;BEATS.EXE" 
                                   Foreground="White" 
                                   FontSize="16"
                                   FontWeight="ExtraBold"
                                   FontFamily="{DynamicResource TerminalFont}"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat=' [ AUDIO ANALYZER {0} ]'}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   VerticalAlignment="Bottom"
                                   Margin="5,0,0,2"
                                   FontSize="10"
                                   FontFamily="{DynamicResource TerminalFont}"/>
                    </StackPanel>
                    
                    <!-- System Status (Simulated CLI) -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            Margin="0,2,15,2" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SYSTEM STATUS" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="OK" FontSize="11" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Window Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Minimize -->
                        <Button Content="─" Width="32" Height="24" 
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="Minimize_Click" 
                                AutomationProperties.Name="Minimize"
                                FontSize="11" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Maximize/Restore -->
                        <Button x:Name="MaximizeButton" Content="□" Width="32" Height="24" 
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="Maximize_Click" 
                                AutomationProperties.Name="Maximize"
                                FontSize="11" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Close -->
                        <Button Content="×" Width="32" Height="24" 
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="Close_Click" 
                                AutomationProperties.Name="Close"
                                FontSize="12" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#ff5555"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="{DynamicResource HeaderCornerRadius}" Padding="0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e81123"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Row 1: Main Content (scales uniformly when height is insufficient) -->
            <Grid x:Name="ContentGrid" Grid.Row="1" Margin="{DynamicResource MainPadding}">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>              <!-- Row 0: Title -->
                    <RowDefinition Height="Auto"/>              <!-- Row 1: File Selection -->
                    <RowDefinition Height="Auto"/>              <!-- Row 2: Audio Info -->
                    <RowDefinition Height="*" MinHeight="60"/>  <!-- Row 3: Waveform (flexible) -->
                    <RowDefinition Height="Auto"/>              <!-- Row 4: Loudness -->
                    <RowDefinition Height="Auto"/>              <!-- Row 5: Playback -->
                    <RowDefinition Height="Auto"/>              <!-- Row 6: Status -->
                    <RowDefinition Height="Auto"/>              <!-- Row 7: BPM Range -->
                    <RowDefinition Height="Auto"/>              <!-- Row 8: Analyze -->
                    <RowDefinition Height="Auto" MinHeight="80"/> <!-- Row 9: Results -->
                    <RowDefinition Height="28"/>               <!-- Row 10: Footer (fixed) -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
        
        <!-- Row 0: Title centered with floating Theme Button -->
        <Grid Grid.Row="0" Margin="{DynamicResource SectionMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Theme Button - Right side -->
            <Button Grid.Column="2" Content="🎨" Command="{Binding CycleThemeCommand}" 
                    HorizontalAlignment="Right"
                    Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    FontSize="20" Cursor="Hand" 
                    ToolTip="Cambiar tema"/>
            
            <!-- Title + Logo - Centered -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="Tone &amp; Beats" FontSize="24" FontWeight="Bold" 
                           Foreground="{DynamicResource TitleBrush}" HorizontalAlignment="Center"/>
                 <Image x:Name="LogoImage" Height="40" 
                        HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        
        <!-- Row 1: File Selection -->
        <Border Grid.Row="1" Style="{StaticResource ResultBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource FileNameInactiveBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFileSelected}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource FileNameActiveBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse" Command="{Binding BrowseCommand}" Width="80"/>
            </Grid>
        </Border>
        
        <!-- Row 2: Audio File Info (Dynamic Summary) -->
        <Border Grid.Row="2" Style="{StaticResource ResultBox}">
            <TextBlock Text="{Binding AudioInfoSummary}" 
                       FontSize="13" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource ForegroundBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{DynamicResource TerminalFont}"/>
        </Border>
        
        <!-- Row 3: Waveform (with playhead) -->
        <Border Grid.Row="3" Style="{StaticResource ResultBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Waveform Header -->
                <Grid Grid.Row="0" Margin="5,2">
                    <TextBlock Text="WAVEFORM" FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontFamily="{DynamicResource TerminalFont}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="DURATION: " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                        <TextBlock Text="{Binding DurationText}" FontSize="9" Foreground="{DynamicResource ForegroundBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                    </StackPanel>
                </Grid>
                
                <controls:WaveformControl Grid.Row="1" x:Name="WaveformDisplay" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="60"/>
            </Grid>
        </Border>
        
        <!-- Row 4: Loudness (NEW) -->
        <Border Grid.Row="4" Style="{StaticResource ResultBox}" ToolTip="{Binding LoudnessResult.ErrorMessage}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LUFS Integrated -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="LUFS" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoudnessIntegratedDisplay}" FontSize="20" FontWeight="Bold" 
                              Foreground="{Binding LoudnessIntegratedLevel, Converter={StaticResource LevelToBrushConverter}}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Integrated" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- LRA -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="LRA" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoudnessLraDisplay}" FontSize="20" FontWeight="Bold" 
                              Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="LRA" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- True Peak -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="True Peak" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoudnessTruePeakDisplay}" FontSize="20" FontWeight="Bold" 
                               Foreground="{Binding LoudnessTruePeakLevel, Converter={StaticResource LevelToBrushConverter}}" HorizontalAlignment="Center"/>
                    <TextBlock Text="dBFS" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Row 5: Playback Controls -->
        <Border Grid.Row="5" Style="{StaticResource ResultBox}">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Button Content="▶ Play" Command="{Binding PlayCommand}" Width="80" Margin="5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TransportButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPlaybackState}" Value="Playing">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⏸ Pause" Command="{Binding PauseCommand}" Width="80" Margin="5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TransportButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPlaybackState}" Value="Paused">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryAccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⏹ Stop" Command="{Binding StopCommand}" Style="{StaticResource TransportButton}" Width="80" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PositionText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text=" / " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding DurationText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Row 6: Status -->
        <Border Grid.Row="6" Style="{StaticResource ResultBox}">
            <TextBlock Text="{Binding StatusText}" 
                       FontSize="12" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Foreground" Value="{DynamicResource StatusForegroundBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusState}" Value="Success">
                                <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusState}" Value="Error">
                                <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
        
        <!-- Row 7: BPM Range Selector -->
         <Border Grid.Row="7" Style="{StaticResource ResultBox}">
             <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="BPM Range:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource ForegroundBrush}"/>
                 <ComboBox ItemsSource="{Binding AvailableBpmProfiles}" 
                           SelectedValue="{Binding SelectedBpmProfile}" 
                           SelectedValuePath="Key"
                           Width="180"
                           Background="{DynamicResource ComboBoxBackgroundBrush}"
                           Foreground="{DynamicResource ComboBoxForegroundBrush}"
                           BorderBrush="{DynamicResource ComboBoxBorderBrush}">
                     
                     <ComboBox.ItemTemplate>
                         <DataTemplate>
                             <TextBlock Text="{Binding Value}" Foreground="{DynamicResource ComboBoxForegroundBrush}" />
                         </DataTemplate>
                     </ComboBox.ItemTemplate>
                     
                 </ComboBox>
             </StackPanel>
         </Border>
        
        <!-- Row 8: Analyze Button -->
        <Border Grid.Row="8" Style="{StaticResource ResultBox}">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="AnalyzeButton" Content=">_ ANALYZE AUDIO" Style="{StaticResource AnalyzeButton}" 
                            Command="{Binding AnalyzeCommand}"/>
                    <Button x:Name="SaveMetadataButton" Content="+ WRITE METADATA" Style="{StaticResource SaveMetadataButton}"
                            Margin="10,0,0,0"
                            Command="{Binding SaveMetadataCommand}"
                            IsEnabled="{Binding IsSaveMetadataEnabled}"/>
                </StackPanel>
                <ProgressBar Value="{Binding AnalysisProgress}" Maximum="100" Height="5" 
                            Margin="0,10,0,0" Visibility="{Binding IsAnalysisProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}" 
                            Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource ProgressBarBackgroundBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Row 9: Results (BPM/Key) - Altura fija con filas explícitas -->
        <Border Grid.Row="9" CornerRadius="{DynamicResource ControlCornerRadius}" BorderThickness="{DynamicResource ControlBorderThickness}" BorderBrush="{DynamicResource BorderBrush}">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ResultBox}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAnalysisResults}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasAnalysisResults}" Value="False">
                            <Setter Property="Opacity" Value="0.2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Separador Vertical (Grid.Column 1) -->
                <Border Grid.Column="1" Grid.RowSpan="4" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1,0,0,0" 
                        HorizontalAlignment="Center" Margin="10,5"/>

                <!-- ========== BPM Column ========== -->
                <!-- Header BPM (Row 0) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="BPM" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>

                <!-- Valor BPM (Row 1) -->
                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="BpmValueDisplay"
                           Text="{Binding BpmDisplayText}" FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           MouseLeftButtonDown="BpmText_LeftClick" Cursor="Hand"
                           ToolTip="Click: ×2 → ÷2 → reset">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TitleBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBpmModified}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource BpmModifiedBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBpmSwapped}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.5" To="1.0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="0.9" To="1.0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="0.9" To="1.0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="40" CenterY="20"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- Confidence BPM (Row 2) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding BpmConfidence}" FontSize="10"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- Alternative BPM (Row 3) - espacio siempre reservado -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding AlternativeBpmText}" FontSize="11" FontStyle="Italic"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,2,0,0"
                           MouseLeftButtonDown="BpmSwap_Click" Cursor="Hand"
                           ToolTip="Click para intercambiar BPM"
                           Visibility="{Binding AlternativeBpmText, Converter={StaticResource StringToVisibilityConverter}}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- ========== Swap Button (centro) ========== -->
                <Button Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" 
                        VerticalAlignment="Center" Width="24" Height="24"
                        ToolTip="Intercambiar BPM principal con alternativo"
                        Command="{Binding SwapBpmCommand}"
                        Cursor="Hand"
                        Visibility="{Binding CanSwapBpm, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSwapped}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Viewbox Width="12" Height="12" Stretch="Uniform">
                        <Canvas Width="20" Height="20">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 0,4 L 13,4 L 13,2 L 19,6 L 13,10 L 13,8 L 0,8 Z"/>
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 20,12 L 7,12 L 7,10 L 1,14 L 7,18 L 7,16 L 20,16 Z"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- ========== KEY Column ========== -->
                <!-- Header KEY (Row 0) -->
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="KEY" FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <Button Command="{Binding ToggleKeyboardCommand}" 
                            Content="⌨" FontSize="11" Padding="4,0" Height="18" Margin="8,0,0,0"
                            Style="{StaticResource SaveMetadataButton}" ToolTip="Ver escala en teclado"/>
                </StackPanel>

                <!-- Valor KEY (Row 1) -->
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding KeyDisplayText}" FontSize="32" FontWeight="Bold"
                          Foreground="{DynamicResource KeyForegroundBrush}"
                          HorizontalAlignment="Center" TextAlignment="Center"
                          MouseLeftButtonDown="KeyText_Click" Cursor="Hand"
                          ToolTip="Click para ver tonalidad relativa">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Magenta" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Confidence KEY (Row 2) -->
                <StackPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding KeyConfidence}" FontSize="10"
                              HorizontalAlignment="Center" TextAlignment="Center"
                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ProgressBar Value="{Binding KeyConfidenceValue}" Height="2" Width="40" 
                                 Background="{DynamicResource ProgressBarBackgroundBrush}"
                                 Foreground="{DynamicResource KeyForegroundBrush}"
                                 BorderThickness="0" Margin="0,1,0,0"
                                 Visibility="{Binding KeyConfidenceValue, Converter={StaticResource DoubleToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Tuning KEY (Row 3) -->
                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding TuningText}" FontSize="10"
                          HorizontalAlignment="Center" TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTuningOff}" Value="True">
                                    <Setter Property="Foreground" Value="#FFD700"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
        
        <!-- Row 10: Consolidated Technical Footer -->
        <Border Grid.Row="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,2" VerticalAlignment="Bottom">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Engine Info -->
                <TextBlock Grid.Column="0" Text="{Binding FooterText}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontFamily="{DynamicResource TerminalFont}"/>
                
                <!-- Center: Headroom & About -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="HEADROOM: " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontFamily="{DynamicResource TerminalFont}"/>
                    <TextBlock Text="{Binding HeadroomText}" FontSize="9" Foreground="{DynamicResource ForegroundBrush}" FontWeight="Bold" VerticalAlignment="Center" FontFamily="{DynamicResource TerminalFont}" Margin="0,0,15,0"/>
                    
                    <Button Content="[ ACERCA DE ]" Click="AboutButton_Click" 
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            FontSize="9" Cursor="Hand" VerticalAlignment="Center"
                            FontFamily="{DynamicResource TerminalFont}"/>
                </StackPanel>
                
                <!-- Right: Brand Link -->
                <TextBlock Grid.Column="2" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{DynamicResource TerminalFont}">
                    <Hyperlink NavigateUri="https://www.hostilitymusic.com" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               TextDecorations="None">
                        HOSTILITYMUSIC.COM
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
    
    <!-- Keyboard Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Background="#CC000000" Panel.ZIndex="1000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardOverlayVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Border Width="340" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{StaticResource ResultBox}" Background="#111111" BorderThickness="2">
                <Grid Margin="{DynamicResource MainPadding}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="{DynamicResource SectionMargin}">
                        <TextBlock Text="SCALE ANALYSIS / KEYBOARD VIEW" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                        <Button HorizontalAlignment="Right" Content="[ X ]" Command="{Binding CloseKeyboardCommand}"
                                Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" FontFamily="{DynamicResource TerminalFont}"/>
                    </Grid>
                    
                    <!-- Detected Key Info -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="{DynamicResource SectionMargin}" Padding="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="DETECTED KEY: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                            <Button Command="{Binding ToggleKeyDisplayCommand}" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                                <TextBlock Text="{Binding KeyDisplayText}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource KeyForegroundBrush}" FontFamily="{DynamicResource TerminalFont}"
                                           ToolTip="Click to toggle relative key"/>
                            </Button>
                            <Button Command="{Binding ToggleKeyDisplayCommand}" Background="Transparent" BorderThickness="0" Padding="4,0" Margin="10,0,0,0" Cursor="Hand" ToolTip="Toggle relative major/minor">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="[ REL ]" FontSize="9" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" FontFamily="{DynamicResource TerminalFont}"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRelativeModeActive}" Value="True">
                                                <Setter Property="Content">
                                                    <Setter.Value>
                                                        <TextBlock Text="[ REL ]" FontSize="9" Foreground="{DynamicResource KeyForegroundBrush}" VerticalAlignment="Center" FontWeight="Bold" FontFamily="{DynamicResource TerminalFont}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!-- Piano Keyboard Visualizer (Chromatic Brutalist) -->
                    <Border Grid.Row="2" Height="120" Background="#111" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="{DynamicResource SectionMargin}">
                        <Grid Margin="5">
                            <!-- White Keys -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <!-- C -->
                                    <ColumnDefinition Width="*"/> <!-- D -->
                                    <ColumnDefinition Width="*"/> <!-- E -->
                                    <ColumnDefinition Width="*"/> <!-- F -->
                                    <ColumnDefinition Width="*"/> <!-- G -->
                                    <ColumnDefinition Width="*"/> <!-- A -->
                                    <ColumnDefinition Width="*"/> <!-- B -->
                                </Grid.ColumnDefinitions>
                                
                                <!-- C (0) -->
                                <Border Grid.Column="0" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=0}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=0}"/>
                                    </Grid>
                                </Border>
                                <!-- D (2) -->
                                <Border Grid.Column="1" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=2}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=2}"/>
                                    </Grid>
                                </Border>
                                <!-- E (4) -->
                                <Border Grid.Column="2" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=4}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=4}"/>
                                    </Grid>
                                </Border>
                                <!-- F (5) -->
                                <Border Grid.Column="3" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=5}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=5}"/>
                                    </Grid>
                                </Border>
                                <!-- G (7) -->
                                <Border Grid.Column="4" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=7}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=7}"/>
                                    </Grid>
                                </Border>
                                <!-- A (9) -->
                                <Border Grid.Column="5" Background="White" BorderBrush="#333" BorderThickness="1,1,0,1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=9}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=9}"/>
                                    </Grid>
                                </Border>
                                <!-- B (11) -->
                                <Border Grid.Column="6" Background="White" BorderBrush="#333" BorderThickness="1">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=11}" Opacity="0.6"/>
                                        <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="#CC0000" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=11}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            
                            <!-- Black Keys Overlay -->
                            <Grid IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <!-- C-D -->
                                    <ColumnDefinition Width="*"/> <!-- D-E -->
                                    <ColumnDefinition Width="*"/> <!-- E-F (Gap) -->
                                    <ColumnDefinition Width="*"/> <!-- F-G -->
                                    <ColumnDefinition Width="*"/> <!-- G-A -->
                                    <ColumnDefinition Width="*"/> <!-- A-B -->
                                    <ColumnDefinition Width="*"/> <!-- B-C (Gap) -->
                                </Grid.ColumnDefinitions>
                                
                                <!-- C# (1) -->
                                <Border Grid.Column="0" Width="24" Height="70" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-12,0" Panel.ZIndex="10">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=1}" Opacity="0.8"/>
                                        <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=1}"/>
                                    </Grid>
                                </Border>
                                <!-- D# (3) -->
                                <Border Grid.Column="1" Width="24" Height="70" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-12,0" Panel.ZIndex="10">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=3}" Opacity="0.8"/>
                                        <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=3}"/>
                                    </Grid>
                                </Border>
                                <!-- F# (6) -->
                                <Border Grid.Column="3" Width="24" Height="70" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-12,0" Panel.ZIndex="10">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=6}" Opacity="0.8"/>
                                        <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=6}"/>
                                    </Grid>
                                </Border>
                                <!-- G# (8) -->
                                <Border Grid.Column="4" Width="24" Height="70" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-12,0" Panel.ZIndex="10">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=8}" Opacity="0.8"/>
                                        <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=8}"/>
                                    </Grid>
                                </Border>
                                <!-- A# (10) -->
                                <Border Grid.Column="5" Width="24" Height="70" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-12,0" Panel.ZIndex="10">
                                    <Grid>
                                        <Rectangle Fill="{Binding ScaleNotes, Converter={StaticResource ScaleNoteHighlightConverter}, ConverterParameter=10}" Opacity="0.8"/>
                                        <TextBlock Text="X" FontSize="12" FontWeight="Bold" Foreground="#FF5555" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                 Visibility="{Binding CurrentTonicIndex, Converter={StaticResource TonicMarkerVisibilityConverter}, ConverterParameter=10}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Controls -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center">
                        <Button Command="{Binding PlayScaleCommand}" Style="{StaticResource AnalyzeButton}" Width="200">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IsPlayingScale, Converter={StaticResource PlayScaleTextConverter}}" Margin="0,0,5,0"/>
                                <TextBlock Text=" SCALE PREVIEW" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="MONO SINE WAVE GENERATOR" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Dependency Resolution Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Background="#CC000000" Panel.ZIndex="2000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDependencyMissing}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{StaticResource ResultBox}" Background="#111111" BorderThickness="2">
                <StackPanel Margin="{DynamicResource MainPadding}">
                    <!-- Header -->
                    <TextBlock Text="! CRITICAL DEPENDENCY MISSING" FontSize="14" FontWeight="Bold" Foreground="#ff5555" HorizontalAlignment="Center" Margin="0,0,0,15" FontFamily="{DynamicResource TerminalFont}"/>
                    
                    <TextBlock Text="Tone &amp; Beats requires FFmpeg binaries for Loudness analysis and advanced audio processing." 
                               TextWrapping="Wrap" TextAlignment="Center" FontSize="13" Margin="0,0,0,20" Foreground="{DynamicResource ForegroundBrush}"/>
                    
                    <!-- Action -->
                    <Button Content=">_ RESOLVE &amp; DOWNLOAD FFmpeg" 
                            Command="{Binding ResolveDependenciesCommand}"
                            Style="{StaticResource AnalyzeButton}"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}"
                            HorizontalAlignment="Center" Width="280" Height="50"/>
                    
                    <!-- Progress -->
                    <StackPanel Margin="0,20,0,0" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="DOWNLOADING BINARIES..." FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,5" FontFamily="{DynamicResource TerminalFont}"/>
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="10" 
                                     Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource ProgressBarBackgroundBrush}"/>
                        <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:F0}%}" FontSize="9" HorizontalAlignment="Center" Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <TextBlock Text="* Requires active internet connection" FontSize="9" HorizontalAlignment="Center" Margin="0,20,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{DynamicResource TerminalFont}"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Analysis Loading Overlay -->
        <Border x:Name="AnalysisOverlay" Grid.Row="0" Grid.RowSpan="99"
                CornerRadius="{DynamicResource WindowCornerRadius}"
                IsHitTestVisible="True"
                Visibility="Collapsed" Opacity="0">
            <Border.Background>
                <SolidColorBrush Color="Black" Opacity="0.82"/>
            </Border.Background>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnalyzingInProgress}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="OverlayFadeIn">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.5" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                                <StopStoryboard BeginStoryboardName="OverlayFadeIn"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <Grid>
                <!-- Animated scan line effect -->
                <Border Height="1" VerticalAlignment="Top" Opacity="0.15" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="{DynamicResource PrimaryAccentColor}" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ScanLineTranslate" Y="0"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAnalyzingInProgress}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="ScanLineStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                    From="0" To="700" Duration="0:0:3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="ScanLineStoryboard"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                
                <!-- Center content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                    
                    <!-- Terminal-style header -->
                    <TextBlock Text="TONE&amp;BEATS.EXE" 
                               FontSize="18" FontWeight="ExtraBold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"
                               FontFamily="{DynamicResource TerminalFont}"/>
                    
                    <TextBlock Text="AUDIO ANALYSIS IN PROGRESS" 
                               FontSize="10" FontWeight="Bold"
                               Foreground="White" Opacity="0.6"
                               HorizontalAlignment="Center" Margin="0,0,0,25"
                               FontFamily="{DynamicResource TerminalFont}"/>
                    
                    <!-- Pulsing indicator -->
                    <Border Width="6" Height="6" CornerRadius="3" 
                            Background="{DynamicResource AccentBrush}" 
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnalyzingInProgress}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="PulseIndicator">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2" Duration="0:0:0.8"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseIndicator"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    
                    <!-- Stage text -->
                    <TextBlock Text="{Binding AnalysisStageText}" 
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,15"
                               FontFamily="{DynamicResource TerminalFont}"/>
                    
                    <!-- Progress bar container -->
                    <Border CornerRadius="2" Height="4" 
                            Background="#1AFFFFFF" Margin="20,0,20,8">
                        <Border CornerRadius="2" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                    <Binding Path="AnalysisProgress"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                    
                    <!-- Percentage -->
                    <TextBlock Text="{Binding AnalysisProgress, StringFormat='{}{0:F0}%'}" 
                               FontSize="9"
                               Foreground="White" Opacity="0.5"
                               HorizontalAlignment="Center" Margin="0,0,0,0"
                               FontFamily="{DynamicResource TerminalFont}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Border>
</Window>