<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- iOS Dark Theme - Apple Style Colors -->
    <Color x:Key="PrimaryAccentColor">#0A84FF</Color>
    <Color x:Key="SecondaryAccentColor">#BF5AF2</Color>
    <Color x:Key="BackgroundColor">#000000</Color>
    <Color x:Key="SurfaceColor">#1C1C1E</Color>
    <Color x:Key="BorderColor">#38383A</Color>
    <Color x:Key="SuccessColor">#30D158</Color>
    <Color x:Key="ErrorColor">#FF453A</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <FontFamily x:Key="AppFontFamily">SF Pro Display, Segoe UI Variable Display, Inter, Segoe UI, Roboto</FontFamily>
    <FontFamily x:Key="TerminalFont">Consolas, Lucida Console, Courier New</FontFamily>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource SecondaryAccentColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#121212"/>
    
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#409CFF"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#39393D"/>
    
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#33FFFFFF"/>
    
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#D768F5"/>
    
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#FF453A"/>
    
    <!-- Semantic State Brushes -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BpmModifiedBrush" Color="#FF453A"/>
    <SolidColorBrush x:Key="BpmSwappedBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    
    <!-- ComboBox Specific Brushes -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource PrimaryAccentColor}"/>
    
    <!-- UI Metrics & Spacing -->
    <CornerRadius x:Key="WindowCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="HeaderCornerRadius">14,14,0,0</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">10</CornerRadius>
    <Thickness x:Key="MainBorderThickness">0</Thickness>
    <Thickness x:Key="ControlBorderThickness">0</Thickness>
    
    <system:Double x:Key="GridUnit">8.0</system:Double>
    <Thickness x:Key="MainPadding">16</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,12</Thickness>
    <Thickness x:Key="ControlPadding">12,10</Thickness>

    <!-- Theme Name -->
    <system:String x:Key="ThemeName">iOS Dark</system:String>
    
</ResourceDictionary>

