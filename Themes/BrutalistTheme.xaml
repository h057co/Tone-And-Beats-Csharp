<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Digital Brutalism / CLI Colors -->
    <Color x:Key="PrimaryAccentColor">#FF00CC00</Color> <!-- Terminal Green Opaque -->
    <Color x:Key="SecondaryAccentColor">#FFFF00FF</Color> <!-- Terminal Magenta Opaque -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="#000000"/>
    <FontFamily x:Key="AppFontFamily">Consolas, Lucida Console, Courier New</FontFamily>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource SecondaryAccentColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#111111"/>
    
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#333333"/>
    
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="{StaticResource PrimaryAccentColor}"/>
    
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#CC00CC"/>
    
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#FF0000"/>

    <!-- Semantic State Brushes -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF0000"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="BpmModifiedBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="BpmSwappedBrush" Color="#00FFFF"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#111111"/>

    <!-- ComboBox Specific Brushes -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#FFFFFF"/>
    
    <!-- UI Metrics & Spacing -->
    <CornerRadius x:Key="WindowCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="HeaderCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
    <Thickness x:Key="MainBorderThickness">1</Thickness>
    <Thickness x:Key="ControlBorderThickness">1</Thickness>
    
    <system:Double x:Key="GridUnit">8.0</system:Double>
    <Thickness x:Key="MainPadding">12</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,10</Thickness>
    <Thickness x:Key="ControlPadding">12,10</Thickness>

    <!-- Typography -->
    <FontFamily x:Key="TerminalFont">Consolas, Lucida Console, Courier New</FontFamily>

    <!-- Brutalist Styles -->
    <Style x:Key="BrutalistBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style x:Key="AnalyzeButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AnalyzeButtonBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{DynamicResource ForegroundBrush}" 
                            BorderThickness="2" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource AnalyzeButtonHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAnalyzingInProgress}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PulseStoryboard">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.4" Duration="0:0:0.4"
                                             AutoReverse="True" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SaveMetadataButton" TargetType="Button">
        <Setter Property="Background" Value="#333333"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="15,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{DynamicResource ForegroundBrush}" 
                            BorderThickness="1" 
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <system:String x:Key="ThemeName">Brutalist</system:String>

</ResourceDictionary>
