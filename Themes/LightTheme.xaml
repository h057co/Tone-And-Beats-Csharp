<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Light Theme Colors -->
    <Color x:Key="PrimaryAccentColor">#3498DB</Color>
    <Color x:Key="SecondaryAccentColor">#9B59B6</Color>
    <Color x:Key="BackgroundColor">#F5F5F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="ErrorColor">#E74C3C</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <FontFamily x:Key="AppFontFamily">Segoe UI, Roboto, Helvetica, Arial</FontFamily>
    <FontFamily x:Key="TerminalFont">Consolas, Lucida Console, Courier New</FontFamily>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource SecondaryAccentColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#E8E8E8"/>
    
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2980B9"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#CCCCCC"/>
    
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#9B59B6"/>
    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#1A000000"/>
    
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="{StaticResource SecondaryAccentColor}"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#8E44AD"/>
    
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="{StaticResource PrimaryAccentColor}"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#E74C3C"/>
    
    <!-- Semantic State Brushes -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#999999"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#000000"/>
    <SolidColorBrush x:Key="BpmModifiedBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="BpmSwappedBrush" Color="#2980B9"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    
    <!-- ComboBox Specific Brushes -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource PrimaryAccentColor}"/>
    
    <!-- UI Metrics & Spacing -->
    <CornerRadius x:Key="WindowCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="HeaderCornerRadius">12,12,0,0</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <Thickness x:Key="MainBorderThickness">0</Thickness>
    <Thickness x:Key="ControlBorderThickness">1</Thickness>
    
    <system:Double x:Key="GridUnit">8.0</system:Double>
    <Thickness x:Key="MainPadding">15</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,12</Thickness>
    <Thickness x:Key="ControlPadding">12,10</Thickness>

    <!-- Theme Name -->
    <system:String x:Key="ThemeName">Light</system:String>
    
</ResourceDictionary>

